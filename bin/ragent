#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift(File.join(__dir__, '..', 'lib'))
require 'ragent'
require 'optparse'

options = { workspace: Ragent::Workspace::DEFAULT_PATH, auto_approve: false, keep_runs: true }

OptionParser.new do |opts|
  opts.banner = 'Usage: ragent [options] "your prompt here"'
  opts.on('--repo PATH', 'Path to the target repository (default: /workspace)') do |path|
    options[:workspace] = path
  end
  opts.on('--yes', 'DANGEROUS: auto-approve all proposed patches without prompting') do
    options[:auto_approve] = true
  end
  opts.on('--clean-runs', 'Delete run artifacts (.ragent/runs/) after session ends') do
    options[:keep_runs] = false
  end
end.parse!

if ARGV[0] == 'rollback'
  run_dir = ARGV[1]
  if run_dir.nil?
    warn 'Usage: ragent [options] rollback RUN_DIR'
    exit 1
  end

  run_dir = File.expand_path(run_dir)
  unless Dir.exist?(run_dir)
    warn "Error: '#{run_dir}' does not exist"
    exit 1
  end

  workspace = File.expand_path('../../..', run_dir)
  begin
    Ragent::Workspace.validate!(workspace)
  rescue Ragent::WorkspaceError => e
    warn "Error: #{e.message}"
    exit 1
  end

  begin
    warn Ragent::Rollback.new(workspace).call(run_dir)
  rescue Ragent::Rollback::CheckpointMissing => e
    warn "Error: #{e.message}"
    exit 1
  end
  exit 0
end

prompt = ARGV[0]

if prompt.nil? || prompt.strip.empty?
  warn 'Usage: ragent [options] "your prompt here"'
  exit 1
end

begin
  workspace = Ragent::Workspace.validate!(options[:workspace])
rescue Ragent::WorkspaceError => e
  warn "Error: #{e.message}"
  exit 1
end

Ragent.run(prompt, workspace: workspace, auto_approve: options[:auto_approve], keep_runs: options[:keep_runs])
